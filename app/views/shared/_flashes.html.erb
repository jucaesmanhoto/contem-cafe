<div class="fixed inset-x-0 top-4 z-50 flex justify-center px-4">
  <div class="w-full max-w-lg space-y-3">
    <% if notice %>
      <div data-controller="dismissable" class="flex items-start justify-between gap-4 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-900 shadow-lg shadow-emerald-950/5">
        <p class="text-sm font-medium"><%= notice %></p>
        <button type="button" data-action="click->dismissable#hide" class="text-lg leading-none text-emerald-700 transition hover:text-emerald-950" aria-label="Fechar aviso">&times;</button>
      </div>
    <% end %>

    <% if alert %>
      <div data-controller="dismissable" class="flex items-start justify-between gap-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-950 shadow-lg shadow-amber-950/5">
        <p class="text-sm font-medium"><%= alert %></p>
        <button type="button" data-action="click->dismissable#hide" class="text-lg leading-none text-amber-700 transition hover:text-amber-950" aria-label="Fechar alerta">&times;</button>
      </div>
    <% end %>
  </div>
</div>
