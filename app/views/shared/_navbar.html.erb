<nav class="border-b border-stone-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <%= link_to root_path, class: "flex items-center gap-3" do %>
      <%= image_tag "https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/logo.png", class: "h-10 w-10 rounded-full object-cover shadow-sm", alt: "Contèm Café" %>
      <div class="hidden sm:block">
