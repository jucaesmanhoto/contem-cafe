<% content_for :title, "Sobre o café" %>

<div class="min-h-screen bg-white about-page" data-about-header>

    <div class="relative w-full overflow-hidden about-hero">
      <% if @farm.photo.attached?  %>
        <%= image_tag @farm.photo,
          class: "absolute inset-0 w-full h-full object-cover object-center about-hero-image",
          alt: @farm.name %>
      <% else %>
        <%= image_tag "ivan-santana.webp", class: "absolute inset-0 w-full h-full object-cover", style: "object-position: center 22%;", alt: "Ivan Santana na Fazenda Jangada" %>
      <% end %>
      <div class="absolute inset-0"></div>
        <div class="absolute bottom-0 left-0 p-4 sm:p-6 text-white w-full bg-gradient-to-t from-black/50 to-transparent">
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight leading-tight"><%= @farm.name%></h1>
        <p class="mt-1 text-base opacity-90">Contèm Cafés Especiais - torra sob demanda</p>
      </div>
    </div>

    <div class="sticky top-0 left-0 right-0 z-40 bg-white border-b border-stone-100">
      <div class="max-w-5xl mx-auto flex items-center justify-between px-4 sm:px-6 lg:px-8 h-12">
        <%= link_to root_path, class: "about-back-link inline-flex items-center text-sm font-medium" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Início
        <% end %>
        <span class="about-compact-title text-sm font-semibold text-gray-800"><%= @farm.name %></span>
      </div>
    </div>

  <div class="max-w-5xl mx-auto py-4 px-4 sm:px-6 lg:px-8 bg-white relative">
    <div class="space-y-12">
      <section class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
        <div class="lg:col-span-2 flex flex-col h-full mt-0">
          <h2 class="text-3xl font-bold text-gray-800 mb-4 self-start">Nossa História</h2>
          <div class="prose prose-lg text-gray-700 max-w-none pb-8 lg:pb-0 mt-auto">
            <p>
              <%= @farm.description %>
            </p>
          </div>
          <div class="hidden lg:block border-b border-gray-200 mt-8"></div>
        </div>

        <div class="border-black/20 border p-6">
          <h3 class="text-xl font-semibold text-gray-800 mb-4">Detalhes da Fazenda</h3>
          <ul class="space-y-3 text-gray-600">
            <li class="flex items-start"><strong class="w-28 shrink-0 font-medium">Produtor(a):</strong> <span><%= @farm.farmer %></span></li>
            <li class="flex items-start"><strong class="w-28 shrink-0 font-medium">Cidade:</strong> <span><%= "#{@farm.city}/#{@farm.state}" %></span></li>
            <li class="flex items-start"><strong class="w-28 shrink-0 font-medium">Região:</strong> <span><%= @farm.region %></span></li>
          </ul>
        </div>
      </section>

      <section>
        <h2 class="text-3xl font-bold text-gray-800 mb-6">Cafés</h2>
        <% if @farm.coffees.any? %>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <%= render @farm.coffees %>
          </div>
        <% else %>
          <p class="text-gray-500">Nenhum café cadastrado para esta fazenda.</p>
        <% end %>
      </section>

      <section>
        <h2 class="text-3xl font-bold text-gray-800 mb-6">Como aproveitar melhor</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <article class="border border-stone-200 rounded-lg p-4">
            <h3 class="text-lg font-semibold text-gray-800 mb-2">Moinho</h3>
            <p class="text-gray-600">Moagem média-fina para coado e grossa para prensa. Moa na hora para aproveitar ao máximo o aroma e frescor do seu café.</p>
          </article>
          <article class="border border-stone-200 rounded-lg p-4">
            <h3 class="text-lg font-semibold text-gray-800 mb-2">Receita base</h3>
            <p class="text-gray-600">Prove com uma proporção de 1:15 (20 g de café para 300 ml de água). Depois vá ajustando as quantidades e moagem ao seu paladar.</p>
          </article>
          <article class="border border-stone-200 rounded-lg p-4">
            <h3 class="text-lg font-semibold text-gray-800 mb-2">Temperatura</h3>
            <p class="text-gray-600">Use água entre 92 e 94 graus para destacar a doçura da bebida. Se a água ferver, desligue o fogo e aguarde 40 segundos para usar no seu café.</p>
          </article>
        </div>
      </section>
    </div>
  </div>
</div>

<style>
  .about-page {
    --hero-height: 14rem;
    --compact-opacity: 0;
  }

  .about-back-link {
    color: #4b5563;
    text-decoration: none;
    border-radius: 6px;
    padding: 4px 8px;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .about-back-link:hover {
    color: #111827;
    background: #f3f4f6;
    text-decoration: none;
  }

  .about-hero {
    height: var(--hero-height);
    overflow: hidden;
  }

  .about-hero-image {
    transform: scale(1.05);
    transition: transform 0.2s linear;
  }

  .about-compact-title {
    opacity: var(--compact-opacity);
    transform: translateY(calc((1 - var(--compact-opacity)) * 4px));
    transition: none;
    will-change: opacity, transform;
  }

  .about-payment-copy-box {
    margin: 14px auto 0;
    width: 100%;
    max-width: 420px;
  }

  .about-payment-copy-btn {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #8a1720;
    border-radius: 8px;
    background: #ffffff;
    color: #8a1720;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .about-payment-copy-btn:hover {
    background: #8a1720;
    color: #ffffff;
  }

  .about-payment-copy-feedback {
    display: none;
    margin: 10px 0 0;
    text-align: center;
    color: #555555;
    font-size: 0.95rem;
  }

  .about-payment-copy-feedback.is-visible {
    display: block;
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .about-page {
      --hero-height: 18rem;
    }
  }
</style>

<script>
  document.addEventListener("turbo:load", function() {
    var page = document.querySelector("[data-about-header]");
    if (!page) return;

    var isDesktop = window.innerWidth >= 1024;

    var minHeroRem = 0;
    var maxHeroRem = isDesktop ? 18 : 14;

    var collapseDistance = 400;
    var collapseStart = 80;

    var clamp = function(value, min, max) {
      return Math.min(max, Math.max(min, value));
    };

    var currentProgress = 0;
    var targetProgress = 0;
    var rafId = null;

    var render = function(progress) {
      var heroRem = maxHeroRem - (maxHeroRem - minHeroRem) * progress;

      page.style.setProperty("--hero-height", heroRem + "rem");
      page.style.setProperty("--compact-opacity", progress.toFixed(3));

      var image = page.querySelector(".about-hero-image");

      if (image) {
        image.style.transform =
          "scale(1.08) translateY(" + (progress * 32) + "px)";
      }
    };

    var animate = function() {
      var delta = targetProgress - currentProgress;
      if (Math.abs(delta) < 0.001) {
        currentProgress = targetProgress;
        render(currentProgress);
        rafId = null;
        return;
      }

      currentProgress += delta * 0.14;
      render(currentProgress);
      rafId = window.requestAnimationFrame(animate);
    };

    var onScroll = function() {
      targetProgress = clamp((window.scrollY - collapseStart) / collapseDistance, 0, 1);
      if (!rafId) {
        rafId = window.requestAnimationFrame(animate);
      }
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    document.addEventListener("turbo:before-cache", function() {
      window.removeEventListener("scroll", onScroll);
      if (rafId) {
        window.cancelAnimationFrame(rafId);
        rafId = null;
      }
    }, { once: true });

    var copyButton = document.querySelector(".about-payment-copy-btn");
    var copyFeedback = document.querySelector(".about-payment-copy-feedback");
    if (!copyButton || !copyFeedback) return;

    var paymentLink = copyButton.dataset.copyPaymentLink;

    copyButton.addEventListener("click", async function() {
      if (!paymentLink) return;

      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(paymentLink);
        } else {
          var helperInput = document.createElement("textarea");
          helperInput.value = paymentLink;
          helperInput.setAttribute("readonly", "");
          helperInput.style.position = "absolute";
          helperInput.style.left = "-9999px";
          document.body.appendChild(helperInput);
          helperInput.select();
          document.execCommand("copy");
          document.body.removeChild(helperInput);
        }

        copyFeedback.textContent = "Link copiado. Agora é só colar no navegador ou no app do banco.";
        copyFeedback.classList.add("is-visible");
      } catch (error) {
        copyFeedback.textContent = "Não foi possível copiar automaticamente. Pressione e segure para copiar manualmente.";
        copyFeedback.classList.add("is-visible");
      }
    });
  });
</script>
