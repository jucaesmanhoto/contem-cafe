<div class="grid grid-cols-1 md:flex md:flex-row-auto md:py-8 gap-6 max-w-6xl mx-auto justify-items-center">
  <% farms.each do |farm| %>
    <div class="group relative aspect-8/3 md:aspect-6/3 h-32 rounded-4xl border-2 border-white overflow-hidden cursor-pointer transition-all duration-500 hover:scale-105 hover:rotate-1 shadow-[0_10px_20px_rgba(0,0,0,0.12),0_4px_8px_rgba(0,0,0,0.06)] hover:shadow-[0_20px_30px_rgba(0,0,0,0.15)]">
      <%= link_to farm_path(farm) do %>
        <%= image_tag farm.photo, class: "w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" %>
        <%# Sombra interna e vinheta %>
        <div class="absolute inset-0 pointer-events-none rounded-[28px] shadow-[inset_0_0_15px_rgba(0,0,0,0.2)] bg-linear-to-br from-white/10 via-transparent to-black/10"></div>
        <%# Brilho especular no topo — simula reflexo de luz %>
        <div class="absolute inset-x-0 top-0 h-2/5 pointer-events-none bg-linear-to-b from-white/50 to-transparent rounded-t-[28px]"></div>
        <%# Gradiente escuro no rodapé para legibilidade %>
        <div class="absolute inset-x-0 bottom-0 h-2/5 pointer-events-none bg-linear-to-t from-black/60 to-transparent"></div>
        <div class="absolute inset-0 flex items-center justify-center px-3 text-center">
          <span class="text-white font-black text-4xl tracking-wide drop-shadow-lg leading-tight"><%= farm.name %></span>
        </div>
        <% if farm.coffees.reject{ |coffee| coffee.price.nil? }.empty? %>
          <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-30 select-none p-4">
            <%= image_tag 'esgotado.png', class: "w-3/4 h-auto max-h-full object-contain transform -rotate-12 drop-shadow-lg transition-transform duration-500 group-hover:scale-110 group-hover:-rotate-6" %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
